# protoPen — SteamOS runtime image (Arch base; run rootful + --privileged).
# Architecture & on-Deck validation: docs/plans/2026-06-20-steamos-native-distribution.md
# Tracker: protopen-3t5.1 (epic protopen-3t5)
#
# Why Arch + uv instead of the repo's Debian Dockerfile: that image is the
# fleet/production container (non-root, OSINT-subset only). The Deck runtime must
# run rootful --privileged for WiFi monitor mode / raw sockets / SDR (proven in
# protopen-2n5: rootless can't, the cap set is namespaced). Arch gives the same
# pacman toolchain the Deck runs bare-metal; uv pins python 3.12 because Arch
# ships 3.14, which has no wheels yet for langgraph/gradio/sqlite-vec/PyMuPDF.
#
# Build (on the Deck, /home-backed rootful store — /var is only 230 MB):
#   sudo podman --root /home/deck/.local/share/rootful-podman \
#     --runroot /run/rootful-podman build -f deck/Containerfile -t protopen-runtime:dev .
# Run: deck/run.sh   (privileged, host netns, device passthrough, :7871)
FROM docker.io/library/archlinux:latest

# 1) System toolchain (official Arch repos) + build/runtime libs. The full
#    BlackArch set (sipvicious, thc-ipv6, grgsm, ...) is a follow-up via the
#    BlackArch repo; this core mirrors what the Deck runs bare-metal today.
RUN pacman -Syu --noconfirm --needed \
        base-devel git curl cmake pkgconf \
        iw aircrack-ng bettercap nmap tcpdump wireshark-cli bind \
        hashcat hydra hcxdumptool \
        libusb fftw usbutils \
        uv nodejs npm \
    && pacman -Scc --noconfirm

# 2) TODO(protopen-3t5.1): bake patched libhackrf (PortaPack Mayhem PID 0x6018) —
#    vendor ~/hackrf-portapack-src or add BlackArch. SDR-in-container already
#    proven (protopen-2n5); baking it retires the host-side
#    reinstall.sh-after-every-OS-update chore.

# 3) Python 3.12 via uv (Arch ships 3.14 -> no wheels for the heavy agent deps).
ENV UV_PYTHON_INSTALL_DIR=/opt/uv-python
RUN uv python install 3.12

# 4) protoPen deps into a pinned 3.12 venv (own layer so code edits don't
#    re-resolve deps).
COPY requirements.txt /tmp/requirements.txt
RUN uv venv --python 3.12 /opt/venv \
    && uv pip install --python /opt/venv/bin/python -r /tmp/requirements.txt
ENV PATH=/opt/venv/bin:$PATH \
    PYTHONUNBUFFERED=1

# 5) App source — all top-level modules + apps/web/dist (see .dockerignore).
#    data/ is excluded; the container keeps its own data dir so it never
#    collides with the live :7870 server's knowledge/audit/checkpointer sqlite.
COPY . /opt/protopen
WORKDIR /opt/protopen
EXPOSE 7871
CMD ["bash","-lc","mkdir -p data/knowledge data/audit data/papers && exec python -m server --port ${PROTOPEN_PORT:-7871}"]
