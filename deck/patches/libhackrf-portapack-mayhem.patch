Add PortaPack Mayhem (USB PID 0x6018) support to libhackrf so hackrf_info and the
SDR tools recognise a PortaPack/HackRF running Mayhem firmware (which enumerates as
1d50:6018, not the stock 1d50:6089). Mirrors the host-side patch the Deck builds
via ~/hackrf-portapack-src; baking it into the image retires the
reinstall.sh-after-every-OS-update chore. Tracker: protopen-3t5.1.

diff --git a/host/libhackrf/src/hackrf.c b/host/libhackrf/src/hackrf.c
index 48a2586..a2f43c4 100644
--- a/host/libhackrf/src/hackrf.c
+++ b/host/libhackrf/src/hackrf.c
@@ -197,6 +197,7 @@ static const uint16_t hackrf_usb_vid = 0x1d50;
 static const uint16_t hackrf_jawbreaker_usb_pid = 0x604b;
 static const uint16_t hackrf_one_usb_pid = 0x6089;
 static const uint16_t rad1o_usb_pid = 0xcc15;
+static const uint16_t portapack_mayhem_usb_pid = 0x6018;
 static uint16_t open_devices = 0;

 static int create_transfer_thread(hackrf_device* device);
@@ -583,7 +584,8 @@ hackrf_device_list_t* ADDCALL hackrf_device_list()
 		if (device_descriptor.idVendor == hackrf_usb_vid) {
 			if ((device_descriptor.idProduct == hackrf_one_usb_pid) ||
 			    (device_descriptor.idProduct == hackrf_jawbreaker_usb_pid) ||
-			    (device_descriptor.idProduct == rad1o_usb_pid)) {
+			    (device_descriptor.idProduct == rad1o_usb_pid) ||
+			    (device_descriptor.idProduct == portapack_mayhem_usb_pid)) {
 				idx = list->devicecount++;
 				list->usb_board_ids[idx] = device_descriptor.idProduct;
 				list->usb_device_index[idx] = i;
@@ -662,7 +664,8 @@ libusb_device_handle* hackrf_open_usb(const char* const desired_serial_number)
 		if (device_descriptor.idVendor == hackrf_usb_vid) {
 			if ((device_descriptor.idProduct == hackrf_one_usb_pid) ||
 			    (device_descriptor.idProduct == hackrf_jawbreaker_usb_pid) ||
-			    (device_descriptor.idProduct == rad1o_usb_pid)) {
+			    (device_descriptor.idProduct == rad1o_usb_pid) ||
+			    (device_descriptor.idProduct == portapack_mayhem_usb_pid)) {
 				if (desired_serial_number != NULL) {
 					const uint_fast8_t serial_descriptor_index =
 						device_descriptor.iSerialNumber;
@@ -823,6 +826,13 @@ int ADDCALL hackrf_open(hackrf_device** device)
 			rad1o_usb_pid);
 	}

+	if (usb_device == NULL) {
+		usb_device = libusb_open_device_with_vid_pid(
+			g_libusb_context,
+			hackrf_usb_vid,
+			portapack_mayhem_usb_pid);
+	}
+
 	if (usb_device == NULL) {
 		return HACKRF_ERROR_NOT_FOUND;
 	}
