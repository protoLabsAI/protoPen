---
import BaseLayout from "../layouts/BaseLayout.astro";
import Terminal from "../components/Terminal.astro";

const features = [
  {
    title: "Self-driving by design",
    body: "Goal mode, wait/yield/resume, background sub-agents, and a monitor-goal cadence let it run an engagement unattended — and a watchdog recovers it when something stalls or crashes.",
  },
  {
    title: "Hardware-in-the-loop",
    body: "Drives PortaPack H4M, Flipper Zero, WiFi Marauder, and BlackArch from a Steam Deck — RF, WiFi, and RFID assessments from one device you can carry.",
  },
  {
    title: "Scope-aware & local",
    body: "Runs on your hardware against the models you host. Kill-chain phase gating and engagement scoping keep it inside the rules of engagement; goal verifiers never execute shell.",
  },
  {
    title: "An operator console + A2A",
    body: "Headless-first, with a full operator console: chat, skills, playbooks, workflows, and findings. Drive it — or chain it to other agents — over A2A 1.0.",
  },
];
---

<BaseLayout>
  <section class="hero">
    <div class="container hero-stack">
      <p class="eyebrow">pwndeck · pen.protolabs.studio</p>
      <h1>An autonomous pen-testing companion <span class="gradient-text">for the Steam Deck</span></h1>
      <div class="hero-term">
        <Terminal />
      </div>
      <p class="lead">
        Self-driving security engagements on a Steam Deck wired to RF, WiFi, and
        RFID — headless-first, scope-aware, and yours.
      </p>
      <div class="cta">
        <a class="btn btn-primary" href="/docs/tutorials/">Get started</a>
        <a class="btn btn-ghost" href="/docs/">Read the docs</a>
      </div>
    </div>
  </section>

  <section class="features">
    <div class="container">
      <div class="feature-grid">
        {
          features.map((f) => (
            <article class="feature">
              <h3>{f.title}</h3>
              <p>{f.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="install">
    <div class="container install-inner">
      <h2>Built for the Deck</h2>
      <pre class="install-cmd"><span class="prompt">$</span> git clone https://github.com/protoLabsAI/protoPen &amp;&amp; cd protoPen &amp;&amp; python -m server</pre>
      <p class="install-note">
        Then follow the <a href="/docs/tutorials/steam-deck-setup">Steam Deck setup</a> to
        wire up the hardware, or start with the
        <a href="/docs/tutorials/">getting-started tutorial</a>.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding: var(--pl-space-12) 0;
  }
  .hero-stack {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--pl-space-5);
  }
  .eyebrow {
    font-family: var(--pl-font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.04em;
    color: var(--pl-color-fg-muted);
    margin: 0;
  }
  .hero h1 {
    font-size: clamp(2rem, 5vw, 3.2rem);
    margin: 0;
    max-width: 22ch;
  }
  .hero-term {
    width: 100%;
    margin: var(--pl-space-3) 0;
  }
  .lead {
    font-size: 1.15rem;
    color: var(--pl-color-fg-muted);
    max-width: 56ch;
    margin: 0;
  }
  .cta {
    display: flex;
    gap: var(--pl-space-3);
    flex-wrap: wrap;
    justify-content: center;
  }
  .feature-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--pl-space-5);
  }
  .feature {
    padding: var(--pl-space-6);
    border: 1px solid var(--pl-color-border);
    border-radius: calc(var(--pl-radius) * 2);
    background: var(--pl-color-bg-raised);
  }
  .feature h3 {
    margin: 0 0 var(--pl-space-3);
    font-size: 1.05rem;
  }
  .feature p {
    margin: 0;
    color: var(--pl-color-fg-muted);
    font-size: 0.95rem;
  }
  .install {
    padding: var(--pl-space-12) 0 0;
  }
  .install-inner {
    text-align: center;
  }
  .install-cmd {
    display: inline-block;
    margin: var(--pl-space-2) auto var(--pl-space-4);
    padding: var(--pl-space-4) var(--pl-space-6);
    border: 1px solid var(--pl-color-border);
    border-radius: calc(var(--pl-radius) * 2);
    background: var(--pl-color-bg-inset, #08080a);
    font-size: 0.95rem;
    color: var(--pl-color-fg);
    max-width: 100%;
    overflow-x: auto;
  }
  .install-cmd .prompt {
    color: var(--pl-color-brand-lavender);
    margin-right: var(--pl-space-2);
  }
  .install-note {
    color: var(--pl-color-fg-muted);
  }

  @media (max-width: 820px) {
    .feature-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
