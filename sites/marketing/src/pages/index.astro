---
import BaseLayout from "../layouts/BaseLayout.astro";
import Terminal from "../components/Terminal.astro";

// The actual stack, not a pitch — the "$ protopen --whoami" readout.
const stack = [
  { k: "runtime", v: "LangGraph agent · A2A 1.0 · LiteLLM gateway (your models)" },
  { k: "host", v: "SteamOS · rootful --privileged container · survives OS updates" },
  { k: "radios", v: "WiFi monitor + inject · HackRF/PortaPack SDR · Flipper / Marauder" },
  { k: "arsenal", v: "BlackArch · aircrack-ng · bettercap · nmap · hashcat · OSINT" },
];

// Capability blocks — each carries a real readout, not a stock illustration.
const caps = [
  {
    n: "01",
    title: "It drives the engagement — not you",
    body: "Goal mode, wait / yield / resume, background sub-agents, and a monitor-goal cadence let it run unattended. A watchdog recovers it when a step stalls or the process dies. Set the objective and walk away.",
    term: [
      { p: "$", t: 'goal "recon lab subnet · report criticals"' },
      { o: "[plan]  scan → capture → crack → triage → report" },
      { o: "[bg]    sub-agent #2 cracking · watchdog armed" },
    ],
  },
  {
    n: "02",
    title: "Hardware-in-the-loop",
    body: "Real radios, passed straight through a privileged container — monitor-mode WiFi with injection, software-defined radio capture/replay, and serial to the Flipper. One rig you carry, not a rack you ship.",
    term: [
      { p: "$", t: "protopen devices" },
      { o: "wlan1    Alfa mt7921u      monitor + inject" },
      { o: "hackrf   PortaPack/Mayhem  SDR cap · replay" },
      { o: "ttyACM1  Flipper+Marauder  sub-GHz · RFID" },
    ],
  },
  {
    n: "03",
    title: "The whole arsenal, one pacman away",
    body: "The BlackArch repo ships configured, so any of ~2800 tools is one install away — and the agent already wraps the ones it reaches for: WiFi, recon, cracking, web, OSINT, telecom. Add your own skills, playbooks, and workflows on top.",
    term: [
      { p: "$", t: "which aircrack-ng bettercap nmap hashcat" },
      { o: "→ all on PATH · BlackArch repo configured" },
      { p: "$", t: "which maigret holehe sipvicious_svmap" },
      { o: "→ OSINT + telecom wired in" },
    ],
  },
  {
    n: "04",
    title: "Scoped, local, auditable",
    body: "Runs on your hardware against models you host. Engagement scoping and kill-chain phase-gating keep it inside the rules of engagement; goal verifiers are read-only and never execute shell. Every tool call lands in an immutable audit log.",
    term: [
      { o: "engagement  active · scope 10.13.37.0/24" },
      { o: "phase-gate  recon✓  access·  exfil✗" },
      { o: "verifiers   read-only · audit append-only" },
    ],
  },
  {
    n: "05",
    title: "An operator console, or an API",
    body: "Headless-first — but a full terminal-green console rides along: chat, an embedded PTY terminal, findings / targets / intel, and a semantic knowledge store. Drive it yourself, or chain it to other agents over A2A 1.0.",
    term: [
      { p: "$", t: "systemctl --user start protopen" },
      { o: "[pwndeck] online · :7870 · /app · /a2a" },
      { p: "$", t: "curl :7870/.well-known/agent-card" },
      { o: '→ "protoPen"' },
    ],
  },
];
---

<BaseLayout>
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">pwndeck · pen.protolabs.studio</p>
        <h1>A self-driving pentest rig <span class="gradient-text">on a Steam Deck</span></h1>
        <p class="lead">
          protoPen runs the engagement itself — recon, WiFi, RF, RFID, OSINT —
          autonomously, on hardware you carry, against models you host.
          Headless-first, scope-aware, fully auditable.
        </p>
        <div class="cta">
          <a class="btn btn-primary" href="/docs/tutorials/">Get started</a>
          <a class="btn btn-ghost" href="https://github.com/protoLabsAI/protoPen">Source</a>
        </div>
      </div>
      <div class="hero-term">
        <Terminal />
      </div>
    </div>
  </section>

  <section class="stack">
    <div class="container">
      <div class="readout">
        <div class="tline"><span class="prompt">$</span> protopen --whoami</div>
        {
          stack.map((s) => (
            <div class="row">
              <span class="k">{s.k}</span>
              <span class="v">{s.v}</span>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="caps-wrap">
    <div class="container caps">
      {
        caps.map((c) => (
          <article class="cap">
            <div class="cap-head">
              <span class="cap-n">§{c.n}</span>
              <h3>{c.title}</h3>
              <p>{c.body}</p>
            </div>
            <div class="cap-term">
              {c.term.map((l) =>
                l.p ? (
                  <div class="tline">
                    <span class="prompt">{l.p}</span> {l.t}
                  </div>
                ) : (
                  <div class="tline out">{l.o}</div>
                ),
              )}
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <section class="install">
    <div class="container install-inner">
      <h2>Bring it up</h2>
      <div class="install-cmd">
        <div class="tline"><span class="prompt">$</span> git clone https://github.com/protoLabsAI/protoPen &amp;&amp; cd protoPen</div>
        <div class="tline"><span class="prompt">$</span> bash deck/install.sh   <span class="comment"># SteamOS: pulls the image, wires systemd + Game Mode kiosk</span></div>
      </div>
      <p class="install-note">
        Not on a Deck? <code>python -m server</code> runs the agent + console
        anywhere. Then wire the hardware via the
        <a href="/docs/tutorials/steam-deck-setup">Steam Deck setup</a>, or start with the
        <a href="/docs/tutorials/">getting-started tutorial</a>.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  /* Faint phosphor grid + green halo behind the hero — terminal, not garish. */
  .hero {
    position: relative;
    padding: var(--pl-space-12) 0;
    background:
      radial-gradient(60% 50% at 72% 0%, rgba(62, 224, 122, 0.08), transparent 70%),
      linear-gradient(rgba(62, 224, 122, 0.022) 1px, transparent 1px) 0 0 / 100% 28px,
      linear-gradient(90deg, rgba(62, 224, 122, 0.022) 1px, transparent 1px) 0 0 / 28px 100%;
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--pl-space-8);
    align-items: center;
  }
  .eyebrow {
    font-family: var(--pl-font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.04em;
    color: var(--pl-color-accent);
    margin: 0 0 var(--pl-space-4);
  }
  .hero h1 {
    font-size: clamp(2rem, 5vw, 3.2rem);
    margin: 0 0 var(--pl-space-5);
    letter-spacing: -0.01em;
  }
  .lead {
    font-size: 1.1rem;
    color: var(--pl-color-fg-muted);
    max-width: 46ch;
    margin: 0 0 var(--pl-space-6);
  }
  .cta {
    display: flex;
    gap: var(--pl-space-3);
    flex-wrap: wrap;
    margin-bottom: var(--pl-space-5);
  }

  /* Shared terminal line — mono, preserves column spacing, scrolls if long. */
  .tline {
    font-family: var(--pl-font-mono);
    white-space: pre;
  }

  /* The whoami spec strip. */
  .stack {
    padding: var(--pl-space-2) 0 var(--pl-space-10);
  }
  .readout {
    padding: var(--pl-space-5) var(--pl-space-6);
    border: 1px solid var(--pl-color-border);
    border-left: 2px solid var(--pl-color-accent);
    border-radius: calc(var(--pl-radius) * 2);
    background: var(--pl-color-bg-inset, #050506);
    font-size: 0.9rem;
    line-height: 1.8;
    overflow-x: auto;
  }
  .readout .row {
    font-family: var(--pl-font-mono);
  }
  .readout .k {
    display: inline-block;
    width: 9ch;
    color: var(--pl-color-accent);
  }
  .readout .v {
    color: var(--pl-color-fg-muted);
  }

  /* Capability blocks — alternating manpage rows, not a grid of stock cards. */
  .caps {
    display: grid;
    gap: 0;
  }
  .cap {
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    gap: var(--pl-space-7);
    align-items: start;
    padding: var(--pl-space-8) 0;
    border-top: 1px solid var(--pl-color-border);
  }
  .cap-head {
    min-width: 0;
  }
  .cap-n {
    font-family: var(--pl-font-mono);
    font-size: 0.8rem;
    color: var(--pl-color-accent);
    letter-spacing: 0.05em;
  }
  .cap-head h3 {
    font-size: 1.3rem;
    margin: var(--pl-space-2) 0 var(--pl-space-3);
  }
  .cap-head p {
    margin: 0;
    color: var(--pl-color-fg-muted);
    font-size: 0.98rem;
    line-height: 1.6;
    max-width: 54ch;
  }
  .cap-term {
    min-width: 0;
    align-self: center;
    padding: var(--pl-space-4) var(--pl-space-5);
    border: 1px solid var(--pl-color-border);
    border-radius: calc(var(--pl-radius) * 2);
    background: var(--pl-color-bg-inset, #050506);
    box-shadow: var(--pl-shadow-glow);
    font-size: 0.76rem;
    line-height: 1.85;
    color: var(--pl-color-fg);
    overflow-x: auto;
  }
  .cap-term .tline.out {
    color: var(--pl-color-fg-muted);
  }

  .prompt {
    color: var(--pl-color-accent);
    user-select: none;
  }
  .comment {
    color: var(--pl-color-fg-subtle, var(--pl-color-fg-muted));
  }

  .install {
    padding: var(--pl-space-11) 0 var(--pl-space-4);
    text-align: center;
  }
  .install h2 {
    margin-bottom: var(--pl-space-5);
  }
  .install-cmd {
    display: inline-block;
    text-align: left;
    margin: 0 auto var(--pl-space-4);
    padding: var(--pl-space-4) var(--pl-space-6);
    border: 1px solid var(--pl-color-border);
    border-left: 2px solid var(--pl-color-accent);
    border-radius: calc(var(--pl-radius) * 2);
    background: var(--pl-color-bg-inset, #050506);
    font-size: 0.9rem;
    line-height: 2;
    color: var(--pl-color-fg);
    max-width: 100%;
    overflow-x: auto;
  }
  .install-note {
    color: var(--pl-color-fg-muted);
  }
  .install-note code {
    color: var(--pl-color-accent);
    font-size: 0.92em;
  }

  @media (max-width: 820px) {
    .hero-grid {
      grid-template-columns: 1fr;
    }
    .cap {
      grid-template-columns: 1fr;
      gap: var(--pl-space-5);
    }
  }
</style>
